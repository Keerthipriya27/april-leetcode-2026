class Solution:
    def minimumTotalDistance(self, robot: List[int], factory: List[List[int]]) -> int:
        robot.sort()
        factory.sort()     
        n = len(robot)
        m = len(factory)     
        @lru_cache(None)
        def dp(i, j):
            # all robots fixed
            if i == n:
                return 0          
            # no factories left
            if j == m:
                return float('inf')          
            res = dp(i, j + 1)  # skip this factory            
            pos, limit = factory[j]
            cost = 0         
            # try assigning k robots to this factory
            for k in range(1, limit + 1):
                if i + k - 1 >= n:
                    break            
                cost += abs(robot[i + k - 1] - pos)
                res = min(res, cost + dp(i + k, j + 1))        
            return res    
        return dp(0, 0)
